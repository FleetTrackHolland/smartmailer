# ═══════════════════════════════════════════════════════════════
# SmartMailer Ultimate — Ortam Değişkenleri (.env.example)
# ═══════════════════════════════════════════════════════════════

# ─── AI (Anthropic Claude) ────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── BREVO E-POSTA ─────────────────────────────────────────────
BREVO_API_KEY=xkeysib-...
BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
BREVO_SMTP_USER=your@email.com
BREVO_SMTP_PASS=xsmtpsib-...

# ─── GÖNDEREN BİLGİLERİ ──────────────────────────────────────
SENDER_NAME=FleetTrack Holland
SENDER_EMAIL=info@fleettrackholland.nl
COMPANY_NAME=FleetTrack Holland B.V.
COMPANY_KVK=12345678
COMPANY_ADDRESS=Rotterdam, Nederland
COMPANY_PHONE=+31612345678
COMPANY_WEBSITE=https://www.fleettrackholland.nl
UNSUBSCRIBE_URL=https://www.fleettrackholland.nl/afmelden

# ─── ÇALIŞMA MODU ────────────────────────────────────────────
TEST_MODE=true
HUMAN_REVIEW=false
DAILY_SEND_LIMIT=80
DELAY_MIN=25
DELAY_MAX=55

# ─── PERFORMANCE ─────────────────────────────────────────────
QC_MIN_SCORE=90
QC_MAX_RETRIES=5
PARALLEL_WORKERS=3

# ─── FOLLOW-UP ────────────────────────────────────────────────
FOLLOWUP_ENABLED=true
FOLLOWUP_DAY_1=3
FOLLOWUP_DAY_2=7
FOLLOWUP_DAY_3=14

# ─── OTOMASYON ────────────────────────────────────────────────
AUTO_START=true
AUTOMATION_INTERVAL=30
SECTORS=transport,bouw,schoonmaak,logistiek,koerier,verhuisbedrijf,taxi
TARGET_LOCATION=Nederland

# ─── LEAD DISCOVERY (ULTIMATE) ────────────────────────────────
MAX_LEADS_PER_SEARCH=300
PARALLEL_CITY_WORKERS=5
TELEFOONBOEK_ENABLED=true
OPENSTREETMAP_ENABLED=true
EMAIL_VERIFY_MX=true
EMAIL_VERIFY_SMTP=false
